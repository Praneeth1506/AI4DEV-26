# Normalize line endings to LF in the repo; let Git handle CRLF on Windows checkout
* text=auto eol=lf

# Explicitly mark binary files so Git won't touch their line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.webp binary
*.mp4 binary
*.webm binary
